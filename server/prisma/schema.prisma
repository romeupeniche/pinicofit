generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FoodSource {
  TACO
  PINICODB
  USER
}

enum FoodCategory {
  beverage
  fast_food
  dessert
  fruit
  side_dish
  protein
  powders_flours
  vegetables_greens
  sauces_condiments
  dairy
  snack
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String

  age    Int?
  weight Float?
  height Float?
  gender String?
  goal   String?

  isProfileComplete Boolean @default(false)

  foods   Food[]
  meals   Meal[]
  recipes Recipe[]

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  dailyLogs               DailyFoodLog[]
  waterLogs               WaterLog[]
  workoutLogs             WorkoutLog[]
  workoutPresets          WorkoutPreset[]
  workoutSettings         WorkoutSettings?
  userPreferences         UserPreferences?
  foodFavorites           FoodFavorite[]
  mealFavorites           MealFavorite[]
  sleepLogs               SleepLog[]
  tasks                   Task[]
  emailVerificationTokens EmailVerificationToken[]
  monthlyReportDispatches MonthlyReportDispatch[]
  userStreak              UserStreak?
}

model UserPreferences {
  userId        String  @id @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  language      String  @default("en")
  activityLevel String?

  nutritionEnabled Boolean @default(true)
  calorieGoal      Int?    @default(2200)
  nutritionTolerance Int   @default(95)

  proteinGoal    Int?    @default(160)

  carbsGoal    Int?    @default(250)

  fatGoal    Int?    @default(70)

  sodiumGoal Int @default(2300)
  sugarGoal  Int @default(50)

  waterGoal      Int     @default(2000)
  waterTolerance Int     @default(80)
  waterEnabled   Boolean @default(true)

  sleepGoal      Float   @default(8)
  sleepTolerance Int     @default(85)
  sleepEnabled   Boolean @default(true)

  workoutTolerance Int     @default(80)
  workoutEnabled   Boolean @default(true)

  tasksGoal    Int     @default(0)
  tasksEnabled Boolean @default(true)

  nutritionDeactivatedAt DateTime?
  nutritionCooldownUntil DateTime?

  waterDeactivatedAt DateTime?
  waterCooldownUntil DateTime?

  sleepDeactivatedAt DateTime?
  sleepCooldownUntil DateTime?

  workoutDeactivatedAt DateTime?
  workoutCooldownUntil DateTime?

  tasksDeactivatedAt DateTime?
  tasksCooldownUntil DateTime?

  tutorialState       Json     @default("{}")
  notificationsEmail  String?
  avatar              String?
  isEmailVerified     Boolean  @default(false)
  emailAlertsEnabled  Boolean  @default(true)
  emailReportsEnabled Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Food {
  id        String     @id @default(uuid())
  userId    String?
  source    FoodSource @default(PINICODB)
  brandName String?

  brName String
  enName String
  esName String

  kcal    Float
  protein Float
  carbs   Float
  fat     Float
  fiber   Float
  sodium  Float
  sugar   Float

  useML           Boolean      @default(false)
  density         Float        @default(1.0)
  isPublic        Boolean      @default(true)
  allowedMeasures Json
  category        FoodCategory

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  mealItems         MealItem[]
  recipeIngredients RecipeIngredient[]
  dailyLogs         DailyFoodLog[]
  foodFavorites     FoodFavorite[]
}

model FoodFavorite {
  id        String   @id @default(uuid())
  userId    String
  foodId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, foodId])
}

model Meal {
  id          String  @id @default(uuid())
  userId      String?
  name        String
  description String?
  isPublic    Boolean @default(true)

  user  User?      @relation(fields: [userId], references: [id])
  items MealItem[]

  createdAt     DateTime       @default(now())
  mealFavorites MealFavorite[]
}

model MealItem {
  id       String @id @default(uuid())
  mealId   String
  foodId   String
  quantity Float

  meal Meal @relation(fields: [mealId], references: [id])
  food Food @relation(fields: [foodId], references: [id])
}

model MealFavorite {
  id        String   @id @default(uuid())
  userId    String
  mealId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([userId, mealId])
}

model Recipe {
  id           String  @id @default(uuid())
  userId       String?
  title        String
  description  String?
  instructions String
  imageUrl     String?
  source       String?

  user        User?              @relation(fields: [userId], references: [id])
  ingredients RecipeIngredient[]

  totalKcal    Float
  totalProtein Float
  totalCarbs   Float
  totalFat     Float

  createdAt DateTime @default(now())
}

model RecipeIngredient {
  id       String @id @default(uuid())
  recipeId String
  foodId   String
  quantity Float
  measure  String

  recipe Recipe @relation(fields: [recipeId], references: [id])
  food   Food   @relation(fields: [foodId], references: [id])
}

model DailyFoodLog {
  id     String @id @default(uuid())
  userId String
  foodId String

  quantity Float
  measure  String
  kcal     Float
  protein  Float
  carbs    Float
  fat      Float

  date DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId, date])
  @@map("DailyLog")
}

model WaterLog {
  id     String   @id @default(uuid())
  userId String
  amount Int
  date   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model WorkoutLog {
  id        String   @id @default(uuid())
  userId    String
  name      String
  exercises Json
  duration  Int?
  date      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model SleepLog {
  id               String    @id @default(uuid())
  userId           String
  date             DateTime  @db.Date
  sleptAt          DateTime?
  wokeAt           DateTime?
  napStart         DateTime?
  napEnd           DateTime?
  napDurationHours Float     @default(0)
  durationHours    Float
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Task {
  id                String    @id @default(uuid())
  userId            String
  title             String
  notes             String?
  isDaily           Boolean   @default(false)
  targetDate        DateTime? @db.Date
  reminderAt        DateTime?
  lastCompletedDate DateTime? @db.Date
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutPreset {
  id        String   @id @default(uuid())
  userId    String
  name      String
  exercises Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WorkoutSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  state     Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  email     String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model MonthlyReportDispatch {
  id       String   @id @default(uuid())
  userId   String
  monthKey String
  sentAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
}

enum FlameLevel {
  low
  streak
  max
}

model UserStreak {
  userId String @id @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  streakCount      Int        @default(0)
  livesRemaining   Int        @default(5)
  maxLivesPerMonth Int        @default(5)
  flameLevel       FlameLevel @default(low)

  lastProcessedDate DateTime? @db.Date
  livesMonthKey     String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days UserStreakDay[]
}

model UserStreakDay {
  id     String   @id @default(uuid())
  userId String
  date   DateTime @db.Date

  contractMet Boolean @default(false)
  missingGoals Json   @default("[]")
  lifeUsed     Boolean @default(false)

  streakBefore Int @default(0)
  streakAfter  Int @default(0)
  livesBefore  Int @default(0)
  livesAfter   Int @default(0)

  evaluatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userStreak UserStreak @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}
